{
  "name": "securecrypt",
  "version": "0.1.0",
  "description": "Secure file encryption/decryption application for Windows",
  "main": "dist/cli/cliRunner.js",
  "bin": {
    "securecrypt": "dist/cli/cliRunner.js"
  },
  "scripts": {
    "dev": "tsx src/cli/cliRunner.ts",
    "dev:web": "tsx src/web/server.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:web\"",
    "build": "tsc",
    "start:web": "node dist/web/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": ["encryption", "aes-256-gcm", "argon2", "security", "cli"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "argon2": "^0.40.3",
    "commander": "^12.1.0",
    "cli-progress": "^3.12.0",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
