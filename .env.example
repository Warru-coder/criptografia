# =============================================================================
# SecureCrypt — Environment Configuration
# =============================================================================
# Copy this file to .env and edit the values for your environment.
# For LOCAL development: most defaults work out of the box.
# For HOSTING/PRODUCTION: fill in every section marked [PRODUCTION].
# =============================================================================

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
# [PRODUCTION] Set to "true" if behind a reverse proxy (Nginx, Cloudflare, etc.)
TRUST_PROXY=false

# ─── Storage ──────────────────────────────────────────────────────────────────
# Directory for user data, database and logs.
# Default: ~/.securecrypt
# [PRODUCTION/DOCKER] Use an absolute path on a persistent volume.
DATA_DIR=

# ─── Security ─────────────────────────────────────────────────────────────────
# [PRODUCTION] REQUIRED — 64-char hex string, used to wrap user master keys.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SERVER_SECRET=

SESSION_TTL_MINUTES=30
# Global rate limit (requests / window per IP)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# Login-specific rate limit (stricter)
LOGIN_RATE_LIMIT_MAX=10

# [PRODUCTION] Comma-separated allowed CORS origins (empty = same-origin only)
# Example: https://app.example.com,https://www.example.com
CORS_ORIGINS=

# ─── WebAuthn / FIDO2 ─────────────────────────────────────────────────────────
# [PRODUCTION] Change these to match your actual domain.
RP_NAME=SecureCrypt
# RP_ID must equal the registering origin's eTLD+1 (no port, no scheme)
RP_ID=localhost
# Full origin used during WebAuthn ceremonies
RP_ORIGIN=http://localhost:3000
# Set to "false" to disable passkey login
ENABLE_WEBAUTHN=true

# ─── Registration ─────────────────────────────────────────────────────────────
# Set to "false" to prevent new user sign-ups on a deployed instance
ENABLE_REGISTRATION=true

# ─── AI / Ollama ──────────────────────────────────────────────────────────────
# Local Ollama instance. Change OLLAMA_BASE_URL to point to a remote host if needed.
OLLAMA_BASE_URL=http://localhost:11434/v1
# Recommended models by available RAM:
#   4 GB  RAM → llama3.2:3b           (default, fast, good quality)
#   8 GB  RAM → llama3.1:8b           (better reasoning)
#   16 GB RAM → qwen2.5-coder:7b-instruct-q4_K_M  (best for crypto/code questions)
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_MS=120000
# Set to "false" to disable the AI endpoints entirely
ENABLE_AI=true

# ─── File upload limits ───────────────────────────────────────────────────────
# Maximum file size per upload in MB (default 10 GB)
UPLOAD_LIMIT_MB=10240
