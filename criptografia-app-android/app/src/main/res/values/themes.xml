<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SecureCrypt" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/secure_primary_dark</item>
        <item name="android:navigationBarColor">@color/secure_surface</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
    
    <style name="Theme.SecureCrypt.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/secure_primary_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.SecureCrypt</item>
    </style>
</resources>
