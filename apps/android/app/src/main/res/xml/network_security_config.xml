<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Block all cleartext traffic - security first -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    
    <!-- No domains allowed to use cleartext -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.securecrypt.com</domain>
    </domain-config>
</network-security-config>
